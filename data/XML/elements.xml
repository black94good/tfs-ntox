		<!-- Fraco contra Raiton -->
		<element type="raiton" defense="1.3" attack="0.75" />
		<!-- Neutro contra Fuuton -->
		<element type="fuuton" defense="1.0" attack="1.0" />
		<!-- Neutro contra Doton -->
		<element type="doton" defense="1.0" attack="1.0" />
	</race>

	<race id="8" name="Doton" racetype="doton" description="Earth Release">
		<!-- Doton vs Doton -->
		<element type="doton" defense="0.85" attack="1.15" />
		<!-- Forte contra Suiton -->
		<element type="suiton" defense="0.85" attack="1.25" />
		<!-- Fraco contra Raiton -->
		<element type="raiton" defense="1.35" attack="0.7" />
		<!-- Neutro contra Katon -->
		<element type="katon" defense="1.0" attack="1.0" />
		<!-- Neutro contra Fuuton -->
		<element type="fuuton" defense="1.0" attack="1.0" />
	</race>

	<race id="9" name="Raiton" racetype="raiton" description="Lightning Release">
		<!-- Raiton vs Raiton -->
		<element type="raiton" defense="0.9" attack="1.2" />
		<!-- Forte contra Doton -->
		<element type="doton" defense="0.8" attack="1.3" />
		<!-- Fraco contra Fuuton -->
		<element type="fuuton" defense="1.3" attack="0.75" />
		<!-- Neutro contra Katon -->
		<element type="katon" defense="1.0" attack="1.0" />
		<!-- Neutro contra Suiton -->
		<element type="suiton" defense="1.0" attack="1.0" />
	</race>

	<race id="10" name="Fuuton" racetype="fuuton" description="Wind Release">
		<!-- Fuuton vs Fuuton -->
		<element type="fuuton" defense="0.9" attack="1.2" />
		<!-- Forte contra Raiton -->
		<element type="raiton" defense="0.8" attack="1.3" />
		<!-- Fraco contra Katon -->
		<element type="katon" defense="1.35" attack="0.7" />
		<!-- Neutro contra Suiton -->
		<element type="suiton" defense="1.0" attack="1.0" />
		<!-- Neutro contra Doton -->
		<element type="doton" defense="1.0" attack="1.0" />
